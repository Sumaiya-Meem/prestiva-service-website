PORT=5000
NODE_ENV=development

# ── Database (optional) ──
# MongoDB Atlas connection string. Leave empty to run email-only (no persistence).
# Free tier (M0) is plenty to start. Get it from: Atlas → Connect → Drivers.
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/prestiva?retryWrites=true&w=majority

# Token protecting the admin quotes endpoint (GET /api/contact). Set to any long secret.
# ADMIN_API_TOKEN=change-me-to-a-long-random-string

# ── Option A: Microsoft Graph (recommended for Microsoft 365 — see EMAIL_SETUP.md) ──
# The ONLY working way to send from a Microsoft 365 mailbox (admin@prestiva.com.au).
# Microsoft retired password/app-password SMTP, so the SMTP option below will NOT
# work for Microsoft 365. Get these from an Entra ID (Azure AD) app registration.
MS_TENANT_ID=your-tenant-id-guid
MS_CLIENT_ID=your-app-client-id-guid
MS_CLIENT_SECRET=your-client-secret-value
MS_SENDER=admin@prestiva.com.au
MAIL_FROM=Prestiva Property Services <admin@prestiva.com.au>
MAIL_FROM_NAME=Prestiva Property Services

# ── Option B: Direct SMTP (cPanel / Gmail only — NOT Microsoft 365) ──
# Used only if the MS_* values above are empty.
# SMTP_HOST=mail.prestiva.com.au
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=admin@prestiva.com.au
# SMTP_PASS=your-email-password
#
# Gmail note: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, and SMTP_PASS must be a
# Google "App Password" (not your normal password) with 2FA enabled.

# ── Option C: Resend API fallback (used only if MS_* and SMTP_* above are empty) ──
# RESEND_API_KEY=your-resend-api-key

# Where quote-form notifications are delivered
ADMIN_EMAIL=admin@prestiva.com.au
