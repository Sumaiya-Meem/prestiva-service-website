PORT=5000
NODE_ENV=development

# ── Option A: Direct SMTP (recommended — sends from your real mailbox) ──
# Fill these with the business email's SMTP credentials (full email access).
# Example for most cPanel / business hosts:
SMTP_HOST=mail.prestiva.com.au
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@prestiva.com.au
SMTP_PASS=your-email-password
MAIL_FROM=Prestiva Property Services <admin@prestiva.com.au>
MAIL_FROM_NAME=Prestiva Property Services

# Gmail note: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, and SMTP_PASS must be a
# Google "App Password" (not your normal password) with 2FA enabled.

# ── Option B: Resend API fallback (used only if SMTP_* above is empty) ──
# RESEND_API_KEY=your-resend-api-key

# Where quote-form notifications are delivered
ADMIN_EMAIL=admin@prestiva.com.au
